#!/usr/bin/make -f

export DH_VERBOSE = 1
export DEB_BUILD_OPTIONS=nostrip

# Determine minimum bootstrap version from Go source (Go 1.24+).
MIN_BOOTSTRAP := $(shell grep 'const minBootstrap' go/src/cmd/dist/buildtool.go 2>/dev/null | cut -d'"' -f2 | sed 's/go//')

# Check if distro's golang-any meets minimum bootstrap requirement.
DISTRO_GO_VERSION := $(shell go version 2>/dev/null | awk '{print $$3}' | sed 's/go//' || echo "0.0.0")
ifeq ($(MIN_BOOTSTRAP),)
# Older Go trees lack minBootstrap; use distro compiler.
BOOTSTRAP_SUFFICIENT := yes
export GOROOT_BOOTSTRAP := $(shell go env GOROOT)
BOOTSTRAP_DIR :=
else
BOOTSTRAP_SUFFICIENT := $(shell printf '%s\n%s\n' "$(MIN_BOOTSTRAP)" "$(DISTRO_GO_VERSION)" | sort -V | head -1 | grep -q "$(MIN_BOOTSTRAP)" && echo "yes" || echo "no")
BOOTSTRAP_DIR := $(CURDIR)/.go-bootstrap
BOOTSTRAP_ARCH := $(shell dpkg --print-architecture)
BOOTSTRAP_URL := https://go.dev/dl/go$(MIN_BOOTSTRAP).linux-$(BOOTSTRAP_ARCH).tar.gz
ifeq ($(BOOTSTRAP_SUFFICIENT),yes)
export GOROOT_BOOTSTRAP := $(shell go env GOROOT)
else
export GOROOT_BOOTSTRAP := $(BOOTSTRAP_DIR)/go
endif
endif

%:
	dh $@

override_dh_auto_configure:
	@echo "Go source needs no configure step."

override_dh_auto_build: ensure_bootstrap
	cd go/src && ./make.bash

ensure_bootstrap:
ifeq ($(BOOTSTRAP_SUFFICIENT),yes)
	@echo "Distro Go $(DISTRO_GO_VERSION) meets bootstrap requirement; using $(GOROOT_BOOTSTRAP)"
else
	@echo "Distro Go $(DISTRO_GO_VERSION) < required $(MIN_BOOTSTRAP); downloading..."
	mkdir -p $(BOOTSTRAP_DIR)
	curl -fsSL $(BOOTSTRAP_URL) | tar -xz -C $(BOOTSTRAP_DIR)
endif

override_dh_auto_install:
	mkdir -p debian/golang-1.24-go/usr/lib/go-1.24
	cp -a go/* debian/golang-1.24-go/usr/lib/go-1.24/

override_dh_auto_test:
	@echo "Skipping Go test suite (all.bash) during package build."

override_dh_strip_nondeterminism:
	@echo "Skipping strip_nondeterminism for upstream Go test fixtures."

override_dh_dwz:
	@echo "Skipping dwz for Go precompiled binaries."

override_dh_shlibdeps:
	@echo "Skipping shlibdeps — Go produces statically linked binaries."

override_dh_auto_clean:
ifneq ($(BOOTSTRAP_DIR),)
	rm -rf $(BOOTSTRAP_DIR)
endif
	dh_auto_clean
